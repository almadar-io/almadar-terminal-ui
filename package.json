{
  "name": "@almadar/terminal-ui",
  "version": "0.1.0",
  "description": "Terminal variant of @almadar/ui built on Ink. Same component names, same props, terminal rendering.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./demo": {
      "import": "./dist/demo.js"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/almadar-io/almadar-terminal-ui.git"
  },
  "scripts": {
    "build": "tsup",
    "build:watch": "tsup --watch",
    "dev": "tsx src/demo.tsx",
    "typecheck": "tsc --noEmit",
    "test": "echo \"No tests yet\"",
    "prepare": "git config core.hooksPath .githooks"
  },
  "dependencies": {
    "ink": "^6.0.0",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "ink-select-input": "^6.0.0",
    "react": "^19.0.0"
  },
  "devDependencies": {
    "@almadar/eslint-plugin": ">=2.3.0",
    "@types/react": "^19.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "tsup": "^8.0.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0"
  },
  "license": "BSL-1.1",
  "keywords": [
    "almadar",
    "terminal",
    "ui",
    "ink",
    "cli",
    "tui",
    "react"
  ],
  "homepage": "https://github.com/almadar-io/almadar-terminal-ui#readme"
}
